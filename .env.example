#
# Copy to ".env" and fill values:
#   - Windows (PowerShell): Copy-Item .env.example .env
#   - macOS/Linux:         cp .env.example .env
#
# Settings selection:
#   DJANGO_ENV=dev  -> uses SQLite (default)
#   DJANGO_ENV=prod -> uses Postgres (requires DB_* variables)
#

# dev | prod (defaults to dev if not set)
DJANGO_ENV=dev

# Django core
# - DEBUG should be False in production
DEBUG=True

# Django secret key
# - In production: use a long random value and keep it secret
SECRET_KEY=change-me-in-prod

# Comma-separated hostnames/IPs allowed to serve your app
# - Example (dev): localhost,127.0.0.1
# - Example (prod): api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (Cross-Origin Resource Sharing)
# - dev: you can allow all origins (True) for local development
# - prod: strongly recommended to set this False and list CORS_ALLOWED_ORIGINS
CORS_ORIGIN_ALLOW_ALL=True

# Comma-separated list of allowed frontend origins (only used when CORS_ORIGIN_ALLOW_ALL=False)
# Example:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=

# CSRF trusted origins (comma-separated)
# Must include scheme (http/https). Example:
# CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://app.example.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Postgres database (required when DJANGO_ENV=prod)
DB_NAME=kas_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

